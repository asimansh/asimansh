rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Personalities collection
    match /personalities/{personalityId} {
      allow get, list: if true;
      
      // Allow vote increment:
      // 1. Must be signed in
      // 2. Only the 'votes' field changes by exactly +1
      // 3. A corresponding vote document must be created in the same batch
      allow update: if isSignedIn() && 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes'])) &&
        (request.resource.data.votes == resource.data.votes + 1) &&
        existsAfter(/databases/$(database)/documents/votes/$(request.auth.uid + "_" + personalityId));
        
      // Allow admin creation
      allow create: if isSignedIn() && request.auth.token.email == 'asimbyans@gmail.com';
    }

    // Tributes collection
    match /tributes/{tributeId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.message.size() <= 200;
    }

    // User Stats collection
    match /users_stats/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
        request.resource.data.votesCount == 1 &&
        request.resource.data.badges.size() == 0;
      allow update: if isOwner(userId) &&
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votesCount', 'badges']));
    }

    // User Profiles collection
    match /users_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Votes collection
    match /votes/{voteId} {
      // Allow users to check their own votes
      allow read: if isSignedIn() && voteId.startsWith(request.auth.uid);
      
      // Allow creation of a vote
      allow create: if isSignedIn() && 
        voteId == request.auth.uid + "_" + request.resource.data.personalityId &&
        request.resource.data.userId == request.auth.uid;
    }
  }
}
